# MongoDB Configuration
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB_NAME="storybook"

# OpenAI Configuration
OPENAI_API_KEY="your-openai-key"
OPENAI_MODEL="gpt-4"  # or gpt-3.5-turbo

# Replicate Configuration (for LLaMA models)
REPLICATE_API_TOKEN="your-replicate-token"
REPLICATE_MODEL="meta/llama-2-70b-chat:02e509c789964a7ea8736978a43525956ef40397be9033abf9fd2badfe68c9e3"

# Research Tools
TAVILY_API_KEY="your-tavily-key"
SERP_API_KEY="your-serpapi-key"  # Optional for Google search
FIRECRAWL_API_KEY="your-firecrawl-key"  # Optional for web scraping

# Vector Database (Optional)
PINECONE_API_KEY="your-pinecone-key"
PINECONE_ENV="your-pinecone-environment"

# Application Settings
DEBUG=True
LOG_LEVEL="INFO"
MAX_TOKENS=8000
TEMPERATURE=0.7
