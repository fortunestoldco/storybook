# MongoDB Configuration
MONGODB_CONNECTION_STRING=mongodb://localhost:27017
MONGODB_DATABASE_NAME=storybook_system

# Model Provider API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
HUGGINGFACE_API_KEY=your-huggingface-api-key-here
REPLICATE_API_KEY=your-replicate-api-key-here

# Azure OpenAI Configuration (optional)
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_DEPLOYMENT_NAME=your-deployment-name
AZURE_API_VERSION=2023-05-15

# AWS Configuration (optional)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# Research API Keys
PERPLEXITY_API_KEY=your-perplexity-api-key-here
TAVILY_API_KEY=your-tavily-api-key-here
EXA_API_KEY=your-exa-api-key-here
ARXIV_API_KEY=your-arxiv-api-key-here
PUBMED_API_KEY=your-pubmed-api-key-here
LINKUP_API_KEY=your-linkup-api-key-here
SERPER_API_KEY=your-serper-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
BING_API_KEY=your-bing-api-key-here

# Research Configuration Defaults
DEFAULT_MAX_RESEARCH_ITERATIONS=3
DEFAULT_QUERIES_PER_ITERATION=3
DEFAULT_QUALITY_THRESHOLD=0.8
ENABLE_RESEARCH_CACHE=true
