# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE_NAME=storybook
MONGODB_COLLECTION_NAME=story_bible
ATLAS_VECTOR_SEARCH_INDEX_NAME=default

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-3.5-turbo-1106

# Optional API Keys
SERPAPI_API_KEY=your_serpapi_key_here
ELEVEN_LABS_API_KEY=your_elevenlabs_key_here

# Model Configuration
DEFAULT_MODEL=gpt-3.5-turbo-1106
TEMPERATURE=0.7
MAX_TOKENS=1024

# Data Storage
DATABASE_URL=sqlite:///./storybook.db
STORY_DIRECTORY=stories

# Logging
LOG_LEVEL=INFO

# Story Settings
STORY_LENGTH_WORDS=750
CHAPTER_LENGTH_WORDS=250
STORY_TONE=adventurous
STORY_TARGET_AGE=8
ENABLE_SEARCH=true
USE_TEXT_TO_SPEECH=false

# LangGraph Settings
MAX_ITERATIONS=50
EARLY_STOPPING_THRESHOLD=0.95

# Tool Settings
IMAGE_GENERATION_MODEL=dall-e-3
