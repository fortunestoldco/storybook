# API Keys
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment
MONGODB_CONNECTION_STRING=mongodb+srv://username:password@cluster.mongodb.net/database
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name

# Model Configuration
USE_GPU=false
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=gpt-4-turbo
RESEARCH_MODEL=gpt-4-turbo
WRITING_MODEL=gpt-4-turbo
PUBLISHING_MODEL=gpt-4-turbo
SUPERVISOR_MODEL=gpt-4-turbo
AUTHOR_RELATIONS_MODEL=gpt-4-turbo

# Ollama Models (when USE_OLLAMA=true)
OLLAMA_DEFAULT_MODEL=llama3
OLLAMA_RESEARCH_MODEL=llama3
OLLAMA_WRITING_MODEL=llama3
OLLAMA_PUBLISHING_MODEL=llama3
OLLAMA_SUPERVISOR_MODEL=llama3

# Database Configuration
DB_NAME=storybook
STORIES_COLLECTION=stories
RESEARCH_COLLECTION=research
BIBLE_COLLECTION=bible
FEEDBACK_COLLECTION=feedback
USER_COLLECTION=users

# Application Settings
MAX_RETRIES=3
BRAINSTORM_SESSION_TIMEOUT=1800
HUMAN_REVIEW_TIMEOUT=86400
LOG_LEVEL=INFO
DEFAULT_WRITERS=1
JOINT_LLM_THRESHOLD=2000

# Vector Database Configuration
VECTOR_INDEX_NAME=storybook-vectors
VECTOR_DIMENSION=1536
